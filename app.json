        "hint": {
          "en": "Control individual zones"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "title": {
              "en": "Device"
            },
            "filter": "driver_id=airbase"
          },
          {
            "type": "autocomplete",
            "name": "zone_name",
            "placeholder": {
              "en": "Zone"
            }
          },
          {
            "type": "checkbox",
            "name": "enabled",
            "title": {
              "en": "Enabled"
            }
          }
